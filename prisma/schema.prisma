generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model users {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  avatar    Bytes?
  birthday  String?
  createdAt DateTime @db.Date
  email     String
  gender    String?
  joinDate  String?
  password  String
  username  String
}
